<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2">
    <h3>Create a New Listing</h3>
    <form action="/listings" method="post" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-lable">Title</label>
            <input type="text" name="listing[title]" placeholder="enter title" class="form-control" required>
            <div class="valid-feedback">Your title looks good..!</div>
        </div>
        
        <div class="mb-3">
            <label for="description" class="form-lable">Description</label>
            <textarea name="listing[description]" placeholder="enter description"  class="form-control" required></textarea>
            <div class="invalid-feedback">Please enter short description</div>
        </div>
        
        
        <div class="mb-3">
            <label for="image" class="form-lable">Upload Listing Image</label>
            <input type="file" name="listing[image]" class="form-control">
            required
        </div>
        <div class="row">
        <div class="mb-3 col-md-4">
            <label for="price" class="form-lable">Price</label>
            <input type="text" name="listing[price]" placeholder="1800" class="form-control" required>
            <div class="invalid-feedback"> Price should be vaild</div>
        </div>
       
        <div class="mb-3 col-md-8">
            <label for="country" class="form-lable">Country</label> 
            <input type="text" name="listing[country]" placeholder="India" class="form-control" required>
            <div class="invalid-feedback">Country name should be vaild</div>
        </div>
        
        </div>
       
        <div class="mb-3">
            <label for="location" class="form-lable">Location</label>
            <input type="text" name="listing[location]" placeholder="New Delhi ,Delhi" class="form-control" required>
            <div class="invalid-feedback">Location name should be vaild</div>
        </div>
        
       
        <button class="btn btn-dark add-btn mt-3">Add</button>
        

    </form>
    </div>
</div>   

